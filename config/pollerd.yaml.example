# =============================================================================
# bot-pollerd 配置模板
# 复制到 ~/.hermes/profiles/<profile>/pollerd.yaml 并填写实际值
# =============================================================================

# ---------------------------------------------------------------------------
# Feishu 机器人配置
#   app_id:      飞书应用 ID（cli_xxx 格式）
#   app_secret:  飞书应用密钥（使用 ${ENV_VAR} 从环境变量读取）
#   bot_open_id: 本机器人的 open_id（用于过滤自己发的消息）
# ---------------------------------------------------------------------------
feishu:
  app_id: "${FEISHU_APP_ID}"
  app_secret: "${FEISHU_APP_SECRET}"
  bot_open_id: "${FEISHU_BOT_OPEN_ID}"

# ---------------------------------------------------------------------------
# Hermes 转发配置
#   host: Hermes Webhook 监听地址（通常是 127.0.0.1）
#   port: Hermes Webhook 监听端口（默认 18999）
# ---------------------------------------------------------------------------
hermes:
  host: "127.0.0.1"
  port: 18999

# ---------------------------------------------------------------------------
# 轮询配置
#   interval_seconds: 每次轮询间隔（秒），建议 3
#   batch_size:       每次从 API 获取的消息数量，建议 20
# ---------------------------------------------------------------------------
polling:
  interval_seconds: 3
  batch_size: 20

# ---------------------------------------------------------------------------
# 群配置
#   chat_id: 飞书群 ID（oc_xxx 格式）
#   mode:    消息模式
#             - at_only:     只处理 @ 本 bot 的消息
#             - mention_all: 处理 @ 了任何人的消息（包括 bot @ bot）
#             - free_at:     免@模式（处理白名单 bot 发来的无 @ 消息）
#   enabled: 是否启用该群（true/false）
# ---------------------------------------------------------------------------
chatrooms:
  # - chat_id: "oc_your_chat_id_1"
  #   mode: "at_only"
  #   enabled: true
  #
  # - chat_id: "oc_your_chat_id_2"
  #   mode: "free_at"
  #   enabled: true

# ---------------------------------------------------------------------------
# 免@白名单
#   免@模式下，只有这里列出的 bot 的消息才会被处理
#   格式：open_id 列表
# ---------------------------------------------------------------------------
free_at_whitelist:
  # - "ou_bot_a"
  # - "ou_bot_b"
